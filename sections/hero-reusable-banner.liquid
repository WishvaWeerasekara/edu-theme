{{ 'section-hero-reusable-banner.css' | asset_url | stylesheet_tag }}

<section class="hero-section">
  <!-- MEDIA -->
  <div class="hero-media">
    {% if section.settings.media_type == 'image' and section.settings.hero_image != blank %}
      {{ section.settings.hero_image | image_url: width: 2000 | image_tag: loading: 'lazy', class: 'hero-image' }}
    {% elsif section.settings.media_type == 'video' and section.settings.video_url != blank %}
      {%- liquid
        assign video_url = section.settings.video_url | strip
        assign video_id = ''
        assign video_type = ''
        
        comment
          Extract YouTube video ID from various URL formats
        endcomment
        if video_url contains 'youtube.com/watch'
          assign video_id = video_url | split: 'v=' | last | split: '&' | first
          assign video_type = 'youtube'
        elsif video_url contains 'youtu.be/'
          assign video_id = video_url | split: 'youtu.be/' | last | split: '?' | first | split: '&' | first
          assign video_type = 'youtube'
        elsif video_url contains 'youtube.com/embed/'
          assign video_id = video_url | split: 'embed/' | last | split: '?' | first
          assign video_type = 'youtube'
        comment
          Extract Vimeo video ID
        endcomment
        elsif video_url contains 'vimeo.com/'
          assign video_id = video_url | split: 'vimeo.com/' | last | split: '?' | first | split: '/' | last
          assign video_type = 'vimeo'
        endif
      -%}
      {% if video_id != blank %}
        <div class="video-wrapper">
          {% if video_type == 'youtube' %}
            <iframe
              src="https://www.youtube.com/embed/{{ video_id }}?autoplay=1&mute=1&loop=1&playlist={{ video_id }}&controls=1&rel=0&modestbranding=1"
              class="js-youtube"
              allow="autoplay; encrypted-media; picture-in-picture"
              allowfullscreen
              title="Hero Banner Video"
              loading="lazy"
            ></iframe>
          {% elsif video_type == 'vimeo' %}
            <iframe
              src="https://player.vimeo.com/video/{{ video_id }}?autoplay=1&muted=1&loop=1&controls=1&background=1"
              class="js-vimeo"
              allow="autoplay; encrypted-media; picture-in-picture"
              allowfullscreen
              title="Hero Banner Video"
              loading="lazy"
            ></iframe>
          {% endif %}
        </div>
      {% else %}
        <div class="video-wrapper">
          <p style="color: #fff; padding: 2rem; text-align: center;">
            Invalid video URL. Please use a valid YouTube or Vimeo URL.
          </p>
        </div>
      {% endif %}
    {% endif %}

    {% if section.settings.dark_overlay %}
      <div
        class="hero-overlay"
        style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
      ></div>
    {% endif %}
  </div>

  <!-- CONTENT -->
  <div class="content-wrapper align-{{ section.settings.content_alignment }}">
    {% if section.settings.show_box %}
      {% assign opacity = section.settings.box_opacity | divided_by: 100.0 %}
      <div
        class="content-box box-{{ section.settings.box_color }}"
        style="
          background-color: 
          {% if section.settings.box_color == 'black' %}
            rgba(0,0,0,{{ opacity }})
          {% else %}
            rgba(255,255,255,{{ opacity }})
          {% endif %};
        "
      >
    {% endif %}

      <div class="hero-content text-{{ section.settings.text_color }} {% if section.settings.text_shadow %}text-shadow{% endif %}">
        {% for block in section.blocks %}
          <div class="hero-block" {{ block.shopify_attributes }}>
            {% if block.settings.heading != blank %}
              <h2 class="hero-heading">{{ block.settings.heading }}</h2>
            {% endif %}
            {% if block.settings.text != blank %}
              <p class="hero-text">{{ block.settings.text }}</p>
            {% endif %}
          </div>
        {% endfor %}

        <!-- CTAs -->
        {% if section.settings.cta_1_text != blank or section.settings.cta_2_text != blank %}
          <div class="cta-wrapper">
            {% if section.settings.cta_1_text != blank %}
              {% if section.settings.cta_1_link != blank %}
                <a
                  href="{{ section.settings.cta_1_link }}"
                  class="cta-btn border-{{ section.settings.cta_border_color }} text-{{ section.settings.cta_text_color }}"
                >
                  {{ section.settings.cta_1_text }}
                </a>
              {% else %}
                <span class="cta-btn border-{{ section.settings.cta_border_color }} text-{{ section.settings.cta_text_color }}">
                  {{ section.settings.cta_1_text }}
                </span>
              {% endif %}
            {% endif %}

            {% if section.settings.cta_2_text != blank %}
              {% if section.settings.cta_2_link != blank %}
                <a
                  href="{{ section.settings.cta_2_link }}"
                  class="cta-btn border-{{ section.settings.cta_border_color }} text-{{ section.settings.cta_text_color }}"
                >
                  {{ section.settings.cta_2_text }}
                </a>
              {% else %}
                <span class="cta-btn border-{{ section.settings.cta_border_color }} text-{{ section.settings.cta_text_color }}">
                  {{ section.settings.cta_2_text }}
                </span>
              {% endif %}
            {% endif %}
          </div>
        {% endif %}
      </div>

    {% if section.settings.show_box %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Reusable Hero Banner",
  "tag": "section",
  "class": "hero-section",
  "settings": [
    {
      "type": "select",
      "id": "media_type",
      "label": "Media Type",
      "options": [
        { "value": "image", "label": "Image" },
        { "value": "video", "label": "Video (Embed)" }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video Embed URL (YouTube, Vimeo)"
    },
    {
      "type": "select",
      "id": "text_color",
      "label": "Text Color",
      "options": [
        { "value": "black", "label": "Black (#0C0C0C)" },
        { "value": "white", "label": "White" }
      ],
      "default": "white"
    },
    {
      "type": "checkbox",
      "id": "text_shadow",
      "label": "Enable Text Drop Shadow",
      "default": false
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "checkbox",
      "id": "show_box",
      "label": "Show Background Box",
      "default": true
    },
    {
      "type": "select",
      "id": "box_color",
      "label": "Box Color",
      "options": [
        { "value": "black", "label": "Black" },
        { "value": "white", "label": "White" }
      ],
      "default": "black"
    },
    {
      "type": "range",
      "id": "box_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60,
      "label": "Box Opacity (%)"
    },
    {
      "type": "checkbox",
      "id": "dark_overlay",
      "label": "Enable Dark Overlay",
      "default": false
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40,
      "label": "Overlay Opacity (%)"
    },
    {
      "type": "url",
      "id": "cta_1_link",
      "label": "CTA 1 Link"
    },
    {
      "type": "text",
      "id": "cta_1_text",
      "label": "CTA 1 Text"
    },
    {
      "type": "url",
      "id": "cta_2_link",
      "label": "CTA 2 Link"
    },
    {
      "type": "text",
      "id": "cta_2_text",
      "label": "CTA 2 Text"
    },
    {
      "type": "select",
      "id": "cta_border_color",
      "label": "CTA Border Color",
      "options": [
        { "value": "black", "label": "Black" },
        { "value": "white", "label": "White" }
      ],
      "default": "white"
    },
    {
      "type": "select",
      "id": "cta_text_color",
      "label": "CTA Text Color",
      "options": [
        { "value": "black", "label": "Black" },
        { "value": "white", "label": "White" }
      ],
      "default": "white"
    }
  ],
  "blocks": [
    {
      "type": "content",
      "name": "Text Block",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reusable Hero Banner"
    }
  ]
}
{% endschema %}
