<section class="hero-section">
  <!-- MEDIA -->
  <div class="hero-media">
    {% if section.settings.media_type == 'image' and section.settings.hero_image != blank %}
      {{ section.settings.hero_image | image_url: width: 2000 | image_tag: loading: 'lazy', class: 'hero-image' }}
    {% elsif section.settings.media_type == 'video' and section.settings.video_url != blank %}
      <div class="video-wrapper">
        {{ section.settings.video_url }}
      </div>
    {% endif %}

    {% if section.settings.dark_overlay %}
      <div
        class="hero-overlay"
        style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
      ></div>
    {% endif %}
  </div>

  <!-- CONTENT -->
  {% if section.blocks.size > 0 %}
    <div class="content-wrapper align-{{ section.settings.content_alignment }} text-{{ section.settings.text_color }} {% if section.settings.text_shadow %}text-shadow{% endif %}">
      {% if section.settings.show_box %}
        <div
          class="content-box box-{{ section.settings.box_color }}"
          style="background-color: rgba(0,0,0,{{ section.settings.box_opacity | divided_by: 100.0 }});"
        >
      {% endif %}

      {% for block in section.blocks %}
        <div class="hero-block">
          {% if block.settings.heading != blank %}
            <h2>{{ block.settings.heading }}</h2>
          {% endif %}
          {% if block.settings.text != blank %}
            <p>{{ block.settings.text }}</p>
          {% endif %}
        </div>
      {% endfor %}

      <!-- CTAs -->
      <div class="cta-wrapper">
        {% if section.settings.cta_1_text != blank %}
          <a
            href="{{ section.settings.cta_1_link }}"
            class="cta-btn border-{{ section.settings.cta_border_color }} text-{{ section.settings.cta_text_color }}"
          >
            {{ section.settings.cta_1_text }}
          </a>
        {% endif %}

        {% if section.settings.cta_2_text != blank %}
          <a
            href="{{ section.settings.cta_2_link }}"
            class="cta-btn border-{{ section.settings.cta_border_color }} text-{{ section.settings.cta_text_color }}"
          >
            {{ section.settings.cta_2_text }}
          </a>
        {% endif %}
      </div>

      {% if section.settings.show_box %}
        </div>
      {% endif %}
    </div>
  {% endif %}
</section>
{% schema %}
{
  "name": "Reusable Hero Banner",
  "tag": "section",
  "class": "hero-section",
  "settings": [
    {
      "type": "select",
      "id": "media_type",
      "label": "Media Type",
      "options": [
        { "value": "image", "label": "Image" },
        { "value": "video", "label": "Video (Embed)" }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video Embed URL (YouTube, Vimeo)"
    },
    {
      "type": "select",
      "id": "text_color",
      "label": "Text Color",
      "options": [
        { "value": "black", "label": "Black (#0C0C0C)" },
        { "value": "white", "label": "White" }
      ],
      "default": "white"
    },
    {
      "type": "checkbox",
      "id": "text_shadow",
      "label": "Enable Text Drop Shadow",
      "default": false
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "checkbox",
      "id": "show_box",
      "label": "Show Background Box",
      "default": true
    },
    {
      "type": "select",
      "id": "box_color",
      "label": "Box Color",
      "options": [
        { "value": "black", "label": "Black" },
        { "value": "white", "label": "White" }
      ],
      "default": "black"
    },
    {
      "type": "range",
      "id": "box_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60,
      "label": "Box Opacity (%)"
    },
    {
      "type": "checkbox",
      "id": "dark_overlay",
      "label": "Enable Dark Overlay",
      "default": false
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40,
      "label": "Overlay Opacity (%)"
    },
    {
      "type": "url",
      "id": "cta_1_link",
      "label": "CTA 1 Link"
    },
    {
      "type": "text",
      "id": "cta_1_text",
      "label": "CTA 1 Text"
    },
    {
      "type": "url",
      "id": "cta_2_link",
      "label": "CTA 2 Link"
    },
    {
      "type": "text",
      "id": "cta_2_text",
      "label": "CTA 2 Text"
    },
    {
      "type": "select",
      "id": "cta_border_color",
      "label": "CTA Border Color",
      "options": [
        { "value": "black", "label": "Black" },
        { "value": "white", "label": "White" }
      ],
      "default": "white"
    },
    {
      "type": "select",
      "id": "cta_text_color",
      "label": "CTA Text Color",
      "options": [
        { "value": "black", "label": "Black" },
        { "value": "white", "label": "White" }
      ],
      "default": "white"
    }
  ],
  "blocks": [
    {
      "type": "content",
      "name": "Text Block",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reusable Hero Banner"
    }
  ]
}
{% endschema %}
